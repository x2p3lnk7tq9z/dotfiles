{
    "layer": "top",
    "position": "top",
    "output": "HDMI-A-1",
    "height": 22,
    "spacing": 0,
    "margin-top": 0,
    "margin-bottom": 0,
    "margin-left": 0,
    "margin-right": 0,
    "modules-left": ["hyprland/workspaces"],
    "modules-center": [],
    "modules-right": ["clock"],

    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "1": "一",
            "2": "二",
            "3": "三",
            "4": "四",
            "5": "五",
            "6": "六",
            "7": "七",
            "8": "八",
            "9": "九",
            "10": "十"
        },
        "on-click": "activate",
        "sort-by-number": true,
        "all-outputs": true
    },

    "clock": {
        "format": "{:%H:%M}",
        "tooltip": false
    }
}
