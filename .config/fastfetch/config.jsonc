{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "source": "none",
    "type": "builtin",
  },
  "display": {
    "separator": " ",
    "size": {
      "spaceBeforeUnit": "always",
    },
  },
  "modules": [
    {
      "type": "custom",
      "key": "╭──────────╮",
      "keyColor": "#FFB6C1",
    },
    {
      "type": "kernel",
      "key": "│  kernel │",
      "keyColor": "#FFB6C1",
      "format": "{release}",
    },
    {
      "type": "wm",
      "key": "│ 󰇄 wm     │",
      "keyColor": "#FFB6C1",
      "format": "{pretty-name}",
    },
    {
      "type": "uptime",
      "key": "│ 󰅐 uptime │",
      "keyColor": "#FFB6C1",
    },
    {
      "type": "shell",
      "key": "│  shell  │",
      "keyColor": "#FFB6C1",
      "format": "{pretty-name}",
    },
    {
      "type": "terminal",
      "key": "│  term   │",
      "keyColor": "#FFB6C1",
      "format": "{pretty-name}",
    },
    {
      "type": "cpu",
      "key": "│ 󰍛 cpu    │",
      "keyColor": "#FFB6C1",
      "format": "{name}",
    },
    {
      "type": "memory",
      "key": "│  memory │",
      "keyColor": "#FFB6C1",
      "format": "{used} / {total}",
    },
    {
      "type": "custom",
      "key": "╰──────────╯",
      "keyColor": "#FFB6C1",
    },
  ],
}
